global_defs {
   router_id LVS_DEVEL
}

vrrp_script chk_nginx {
    script "/usr/local/bin/check_nginx.sh"
    interval 2
    weight 2
}

vrrp_instance VI_1 {
    interface eth0
    state {{ 'MASTER' if inventory_hostname == 'lb1' else 'BACKUP' }}
    virtual_router_id 51
    priority {{ 101 if inventory_hostname == 'lb1' else 100 }}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass secret
    }

    virtual_ipaddress {
        {{ vip }}/24
    }

    track_script {
        chk_nginx
    }
}
